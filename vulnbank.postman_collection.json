{
  "info": {
    "name": "VulnBank — Vulnerability Test Suite",
    "_postman_id": "vulnbank-v6-collection",
    "description": "VulnBank v6.0.0 — Deliberately vulnerable banking app for security tool validation. Each request demonstrates a specific CVE/CWE vulnerability.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
