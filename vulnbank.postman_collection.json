            "body": {
              "mode": "raw",
              "raw": "{\"query\": \"*\", \"attribute\": \"uid\"}"
            },
            "description": "CWE-285: No authentication for LDAP search. CWE-200: Returns full entry including passwordHash. Observe: all users with password hashes returned to unauthenticated caller."
          }
        },
